# =============================================================================
# RINU — environment variables
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- Site / app ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_ENV="local"

# --- Feature flags (1 = enabled, 0 or unset = disabled) ---
NEXT_PUBLIC_ENABLE_INVITE_CODE="0"
NEXT_PUBLIC_ENABLE_EMAIL_VALIDATION="0"
NEXT_PUBLIC_ENABLE_REVIEWS="1"
INVITE_CODE=""

# --- Stripe (payments) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_BASE_URL="https://api.stripe.com"
STRIPE_RETURN_URL="http://localhost:3000/book"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Brevo / Sendinblue (email + CRM) ---
BREVO_API_KEY="xkeysib-..."
BREVO_URL="https://api.brevo.com/"
BREVO_TIMEOUT="2m"
BREVO_DEAL_PIPELINE_ID=""
BREVO_CONTACT_PIPELINE_ID=""

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

# --- GCP Storage (photo migration / legacy CDN; prefer Supabase Storage in prod) ---
GCP_PHOTO_BUCKET="rinu-dev-photos"
GCP_CDN_URL="https://storage.googleapis.com/rinu-dev-photos"
GCP_CREDENTIALS=""

# --- iCal sync ---
ICAL_URL="http://localhost:3000/api/ical"
ICAL_UPDATE_RATE="1h"

# --- Cron / background jobs ---
CRON_SECRET=""

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# --- Analytics & marketing ---
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GOOGLE_DOMAIN_VERIFICATION=""
NEXT_PUBLIC_META_DOMAIN_VERIFICATION=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
NEXT_PUBLIC_N8N_WEBHOOK_URL=""
